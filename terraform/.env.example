# Generated by: ./scripts/rockport.sh init
# Stores the Cloudflare API token (not suitable for terraform.tfvars)
export CLOUDFLARE_API_TOKEN="your-api-token-from-cloudflare-console"

# 017 — MFA serial for the rockport-deployer user. Required by every operator-role
# subcommand to mint sts:AssumeRole sessions. Enrol an authenticator-app device on
# rockport-deployer in the AWS console and paste the device ARN here.
# export MFA_SERIAL_NUMBER="arn:aws:iam::ACCOUNT_ID:mfa/rockport-deployer-laptop"

# 018 — MFA serial for the rockport-admin user. Required by `rockport.sh init` and
# any other admin-only subcommand. The RockportAdmin policy explicit-denies actions
# outside a tiny safe-list when aws:MultiFactorAuthPresent is false, so a leaked
# admin access key is useless without the second factor. Enrol a TOTP device on
# rockport-admin in the AWS console and paste the device ARN here.
# export ROCKPORT_ADMIN_MFA_SERIAL="arn:aws:iam::ACCOUNT_ID:mfa/adminuser"

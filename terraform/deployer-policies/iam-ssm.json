{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "IAMRolesAndProfiles",
      "Effect": "Allow",
      "Action": [
        "iam:CreateRole",
        "iam:GetRole",
        "iam:DeleteRole",
        "iam:UpdateAssumeRolePolicy",
        "iam:PutRolePolicy",
        "iam:GetRolePolicy",
        "iam:DeleteRolePolicy",
        "iam:AttachRolePolicy",
        "iam:DetachRolePolicy",
        "iam:ListAttachedRolePolicies",
        "iam:ListRolePolicies",
        "iam:ListInstanceProfilesForRole",
        "iam:PassRole",
        "iam:CreateInstanceProfile",
        "iam:GetInstanceProfile",
        "iam:DeleteInstanceProfile",
        "iam:AddRoleToInstanceProfile",
        "iam:RemoveRoleFromInstanceProfile",
        "iam:TagRole"
      ],
      "Resource": [
        "arn:aws:iam::*:role/rockport*",
        "arn:aws:iam::*:role/dlm-lifecycle-*",
        "arn:aws:iam::*:instance-profile/rockport*"
      ]
    },
    {
      "Sid": "IAMDeployerSelfManage",
      "Effect": "Allow",
      "Action": [
        "iam:CreatePolicy",
        "iam:GetPolicy",
        "iam:DeletePolicy",
        "iam:CreatePolicyVersion",
        "iam:ListPolicyVersions",
        "iam:DeletePolicyVersion",
        "iam:GetPolicyVersion"
      ],
      "Resource": "arn:aws:iam::*:policy/RockportDeployer*"
    },
    {
      "Sid": "IAMDeployerUserManage",
      "Effect": "Allow",
      "Action": [
        "iam:CreateUser",
        "iam:GetUser",
        "iam:ListAttachedUserPolicies",
        "iam:AttachUserPolicy",
        "iam:DetachUserPolicy",
        "iam:ListAccessKeys",
        "iam:CreateAccessKey"
      ],
      "Resource": "arn:aws:iam::*:user/rockport-deployer"
    },
    {
      "Sid": "DenyNonRockportPolicyAttachment",
      "Effect": "Deny",
      "Action": [
        "iam:AttachRolePolicy",
        "iam:DetachRolePolicy"
      ],
      "Resource": "*",
      "Condition": {
        "StringNotLike": {
          "iam:PolicyARN": [
            "arn:aws:iam::*:policy/Rockport*",
            "arn:aws:iam::*:policy/rockport*"
          ]
        }
      }
    },
    {
      "Sid": "SSMParameters",
      "Effect": "Allow",
      "Action": [
        "ssm:GetParameter",
        "ssm:GetParameters",
        "ssm:PutParameter",
        "ssm:DeleteParameter",
        "ssm:AddTagsToResource",
        "ssm:ListTagsForResource"
      ],
      "Resource": "arn:aws:ssm:*:*:parameter/rockport/*"
    },
    {
      "Sid": "SSMDescribeParameters",
      "Effect": "Allow",
      "Action": "ssm:DescribeParameters",
      "Resource": "*"
    },
    {
      "Sid": "SSMPublicParameters",
      "Effect": "Allow",
      "Action": "ssm:GetParameter",
      "Resource": "arn:aws:ssm:*::parameter/aws/service/*"
    },
    {
      "Sid": "SSMCommandsOnInstance",
      "Effect": "Allow",
      "Action": [
        "ssm:SendCommand",
        "ssm:StartSession"
      ],
      "Resource": "arn:aws:ec2:*:*:instance/*",
      "Condition": {
        "StringEquals": {
          "aws:ResourceTag/Project": "rockport"
        }
      }
    },
    {
      "Sid": "SSMCommandDocuments",
      "Effect": "Allow",
      "Action": [
        "ssm:SendCommand",
        "ssm:StartSession"
      ],
      "Resource": "arn:aws:ssm:*::document/*"
    },
    {
      "Sid": "SSMSessionManage",
      "Effect": "Allow",
      "Action": [
        "ssm:GetCommandInvocation",
        "ssm:TerminateSession",
        "ssm:DescribeSessions",
        "ssm:DescribeInstanceInformation"
      ],
      "Resource": "*"
    }
  ]
}

{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ManageDeployerPolicies",
      "Effect": "Allow",
      "Action": [
        "iam:CreatePolicy",
        "iam:GetPolicy",
        "iam:DeletePolicy",
        "iam:CreatePolicyVersion",
        "iam:ListPolicyVersions",
        "iam:DeletePolicyVersion",
        "iam:GetPolicyVersion"
      ],
      "Resource": [
        "arn:aws:iam::*:policy/RockportDeployer*",
        "arn:aws:iam::*:policy/RockportAdmin"
      ]
    },
    {
      "Sid": "ManageDeployerUser",
      "Effect": "Allow",
      "Action": [
        "iam:CreateUser",
        "iam:GetUser",
        "iam:ListAttachedUserPolicies",
        "iam:AttachUserPolicy",
        "iam:DetachUserPolicy",
        "iam:ListAccessKeys",
        "iam:CreateAccessKey"
      ],
      "Resource": [
        "arn:aws:iam::*:user/rockport-deployer",
        "arn:aws:iam::*:user/rockport-admin"
      ]
    },
    {
      "Sid": "ManageMasterKey",
      "Effect": "Allow",
      "Action": [
        "ssm:GetParameter",
        "ssm:PutParameter",
        "ssm:AddTagsToResource"
      ],
      "Resource": "arn:aws:ssm:*:*:parameter/rockport/master-key"
    },
    {
      "Sid": "ManageStateBucket",
      "Effect": "Allow",
      "Action": [
        "s3:CreateBucket",
        "s3:ListBucket",
        "s3:PutBucketVersioning",
        "s3:PutEncryptionConfiguration",
        "s3:PutBucketPublicAccessBlock"
      ],
      "Resource": "arn:aws:s3:::rockport-tfstate-*"
    },
    {
      "Sid": "S3VideoBucket",
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket",
        "s3:ListBucketVersions",
        "s3:GetBucketAcl",
        "s3:DeleteBucket",
        "s3:GetObject",
        "s3:DeleteObject",
        "s3:DeleteObjectVersion"
      ],
      "Resource": [
        "arn:aws:s3:::rockport-video-*",
        "arn:aws:s3:::rockport-video-*/*"
      ]
    },
    {
      "Sid": "AccountDiscovery",
      "Effect": "Allow",
      "Action": "sts:GetCallerIdentity",
      "Resource": "*"
    }
  ]
}
